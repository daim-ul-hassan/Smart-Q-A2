# API keys - never commit secrets
.env
.env.*
.streamlit/secrets.toml

# Generated runtime data
faiss_index/
__pycache__/
*.pyc

# Local editor/tooling
.qoder/

# User-uploaded documents
docs/*.pdf
docs/*.txt

# Allow tracked Streamlit config/examples
!.streamlit/
!.streamlit/*.example
!.streamlit/config.toml
